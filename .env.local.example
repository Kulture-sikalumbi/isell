# Supabase — from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: custom brand mark image (client-provided, must be legally cleared)
# NEXT_PUBLIC_BRAND_MARK_URL=/brand-mark.png

# Wallet / manual mobile money deposits
# Zambia (default): ZMW shown as K — e.g. K50.00
PLATFORM_FEE=25
WALLET_CURRENCY=ZMW
NEXT_PUBLIC_SITE_CURRENCY=ZMW
# International deploy: use USD instead
# WALLET_CURRENCY=USD
# NEXT_PUBLIC_SITE_CURRENCY=USD
# PLATFORM_FEE_USD=1
MERCHANT_MTN_NUMBER=260970105334
MERCHANT_AIRTEL_NUMBER=260970105334
# MERCHANT_BINANCE_ID=your-binance-pay-id

# Payment gateway (optional — wallet is primary)
PAYSTACK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxx

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth — same Client ID from Google Cloud Console (also in Supabase → Auth → Google)
# This enables direct Google sign-in showing YOUR app name, not *.supabase.co
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Default developer API key (used when a tool has no per-tool key set in admin)
DEVELOPER_MASTER_API_KEY=your-developer-master-api-key

# Gemini site assistant (AQ keys use x-goog-api-key header — supported automatically)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Admin email alerts (optional — uses Resend; recipients = all profiles with role admin)
# RESEND_API_KEY=re_xxx
# EMAIL_FROM=iSell Unlocking <orders@yourdomain.com>
