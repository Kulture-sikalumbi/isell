# Supabase — from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: custom brand mark image (client-provided, must be legally cleared)
# NEXT_PUBLIC_BRAND_MARK_URL=/brand-mark.png

# Wallet / manual mobile money deposits
# Zambia (default): ZMW shown as K — e.g. K50.00
# Suggested default when creating new tools in admin (actual fee is set per tool there)
PLATFORM_FEE_PERCENT=20
WALLET_CURRENCY=ZMW
NEXT_PUBLIC_SITE_CURRENCY=ZMW
# International deploy: use USD instead
# WALLET_CURRENCY=USD
# NEXT_PUBLIC_SITE_CURRENCY=USD
# PLATFORM_FEE_PERCENT=1
MERCHANT_MTN_NUMBER=260970105334
MERCHANT_AIRTEL_NUMBER=260970105334
MERCHANT_BINANCE_PAY_ID=826667762
MERCHANT_USDT_TRC20_ADDRESS=TDyR5WXCAWmHUCSGkZp9TDp2fRKen9yaWh
# Legacy alias still supported:
# MERCHANT_BINANCE_ID=826667762

# MTN MoMo API deposits (app-centric OAuth from MTN Developer Portal)
# Consumer Key/Secret from your approved app (Payments V1 attached)
MTN_MOMO_BASE_URL=https://api.mtn.com
MTN_MOMO_TARGET_ENVIRONMENT=sandbox
MTN_MOMO_CONSUMER_KEY=your-consumer-key
MTN_MOMO_CONSUMER_SECRET=your-consumer-secret
# Legacy aliases still supported:
# MTN_MOMO_COLLECTION_API_USER=your-consumer-key
# MTN_MOMO_COLLECTION_API_KEY=your-consumer-secret
# Optional only if your tenant still requires it:
# MTN_MOMO_COLLECTION_SUBSCRIPTION_KEY=
# MTN_MOMO_AUTH_MODE=oauth_client_credentials
# MTN_MOMO_TOKEN_PATH=/oauth/client_credential/accesstoken
# MTN_MOMO_REQUEST_TO_PAY_PATH=/collection/v1_0/requesttopay
# MTN_MOMO_REQUEST_STATUS_PATH=/collection/v1_0/requesttopay/{id}
# MTN_MOMO_CALLBACK_TOKEN=your-callback-secret

# Payment gateway (optional — wallet is primary)
PAYSTACK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxx

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auto sign-out after inactivity on /dashboard and /admin (minutes, default 30)
NEXT_PUBLIC_SESSION_IDLE_TIMEOUT_MINUTES=30

# Google OAuth — same Client ID from Google Cloud Console (also in Supabase → Auth → Google)
# This enables direct Google sign-in showing YOUR app name, not *.supabase.co
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Default developer API key (used when a tool has no per-tool key set in admin)
DEVELOPER_MASTER_API_KEY=your-developer-master-api-key

# Gemini site assistant (AQ keys use x-goog-api-key header — supported automatically)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Admin email alerts (optional — uses Resend; recipients = all profiles with role admin)
# RESEND_API_KEY=re_xxx
# EMAIL_FROM=iSell Unlocks <orders@yourdomain.com>
#
# Azure: set RESEND_API_KEY, EMAIL_FROM, and SUPABASE_SERVICE_ROLE_KEY in App Service
# Configuration AND as GitHub Actions secrets (repo → Settings → Secrets) so CI
# build does not bake undefined into server bundles.
